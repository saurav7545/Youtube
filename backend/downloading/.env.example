DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-backend-name.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-name.vercel.app
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://your-frontend-name.vercel.app
DJANGO_SECRET_KEY=change-this-secret-key

# YouTube Authentication Configuration
# To solve "Sign in to confirm you're not a bot" error, configure browser cookies:
# YT_DL_BROWSER: Browser name (chrome, firefox, brave, edge, safari, chromium)
# YT_DL_BROWSER_PROFILE: Browser profile name (optional, defaults to default profile)
# Example:
# YT_DL_BROWSER=chrome
# YT_DL_BROWSER_PROFILE=Default
#
# IMPORTANT:
# - Local development: use YT_DL_BROWSER.
# - Hosted server (Render/Railway/etc): prefer YT_DL_COOKIES_B64/RAW/FILE.
#   Browser DB is usually unavailable on hosted environments.

# Production-friendly cookie options (Render etc.)
# YT_DL_COOKIES_B64=<base64-encoded full cookies.txt content>
# YT_DL_COOKIES_RAW=<raw cookies.txt content>
# YT_DL_COOKIES_FILE=/absolute/path/to/cookies.txt

# Local helper signing key (optional; defaults to DJANGO_SECRET_KEY)
# YT_LOCAL_HELPER_SIGNING_KEY=change-this-for-local-helper
